{
  "version": "2.13",
  "themes": {
    "device": ["desktop", "tablet", "phone"]
  },
  "children": [
    {
      "type": "frame",
      "name": "Team Section - Монгол ТВ",
      "x": 0,
      "y": 0,
      "width": 1440,
      "height": 900,
      "layout": "vertical",
      "fill": {
        "type": "gradient",
        "gradientType": "linear",
        "rotation": 180,
        "colors": [
          {"color": "#E8F5E9", "position": 0},
          {"color": "#ffffff", "position": 1}
        ]
      },
      "clip": true,
      "children": [
        {
          "type": "frame",
          "name": "Navigation",
          "layout": "horizontal",
          "width": "fill_container",
          "padding": [20, 80],
          "alignItems": "center",
          "justifyContent": "space_between",
          "children": [
            {
              "type": "text",
              "name": "Logo",
              "content": "МОНГОЛ ТВ",
              "fontFamily": "Inter",
              "fontSize": 24,
              "fontWeight": "700",
              "fill": "#18191b"
            },
            {
              "type": "frame",
              "name": "Nav-Links",
              "layout": "horizontal",
              "gap": 32,
              "alignItems": "center",
              "children": [
                {
                  "type": "text",
                  "name": "Nav-Home",
                  "content": "Нүүр",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "500",
                  "fill": "#6a6a6c"
                },
                {
                  "type": "text",
                  "name": "Nav-About",
                  "content": "Бидний тухай",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "500",
                  "fill": "#6a6a6c"
                },
                {
                  "type": "text",
                  "name": "Nav-Services",
                  "content": "Үйлчилгээ",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "500",
                  "fill": "#6a6a6c"
                },
                {
                  "type": "text",
                  "name": "Nav-Team",
                  "content": "Баг",
                  "fontFamily": "Inter",
                  "fontSize": 14,
                  "fontWeight": "600",
                  "fill": "#4CAF50"
                }
              ]
            }
          ]
        },
        {
          "type": "frame",
          "name": "Team-Header",
          "layout": "vertical",
          "width": "fill_container",
          "padding": [40, 80],
          "gap": 16,
          "alignItems": "center",
          "children": [
            {
              "type": "frame",
              "name": "Label-Badge",
              "layout": "horizontal",
              "padding": [8, 16],
              "fill": "#ffffff",
              "cornerRadius": 999,
              "stroke": "#4CAF50",
              "strokeWidth": 1,
              "alignItems": "center",
              "children": [
                {
                  "type": "text",
                  "name": "Team-Label",
                  "content": "БАГИЙН ГИШҮҮД",
                  "fontFamily": "Inter",
                  "fontSize": 12,
                  "fontWeight": "600",
                  "letterSpacing": 2,
                  "fill": "#4CAF50"
                }
              ]
            },
            {
              "type": "text",
              "name": "Team-Title",
              "content": "Удирдах баг",
              "fontFamily": "Inter",
              "fontSize": 42,
              "fontWeight": "700",
              "fill": "#18191b"
            },
            {
              "type": "text",
              "name": "Team-Subtitle",
              "content": "Монгол ТВ-ийн удирдах багийн гишүүд",
              "fontFamily": "Inter",
              "fontSize": 16,
              "fill": "#6a6a6c"
            }
          ]
        },
        {
          "type": "frame",
          "name": "Team-Grid",
          "layout": "horizontal",
          "width": "fill_container",
          "padding": [0, 80],
          "gap": 32,
