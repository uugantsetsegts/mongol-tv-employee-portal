              "stroke": "#c4c4c4",
              "strokeWidth": 1,
              "alignItems": "center",
              "children": [
                {
                  "type": "frame",
                  "name": "Avatar-1",
                  "width": 120,
                  "height": 120,
                  "fill": {
                    "type": "gradient",
                    "gradientType": "linear",
                    "rotation": 135,
                    "colors": [
                      {"color": "#667eea", "position": 0},
                      {"color": "#764ba2", "position": 1}
                    ]
